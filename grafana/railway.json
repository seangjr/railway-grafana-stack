{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "/grafana/dockerfile"
    },
    "deploy": {
        "runtime": "V2",
        "numReplicas": 1,
        "healthcheckPath": "/api/health",
        "sleepApplication": false,
        "serverless": true,
        "multiRegionConfig": {
            "us-east4-eqdc4a": {
                "numReplicas": 1
            }
        },
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}