{
  "$schema": "https://railway.com/railway.schema.json",
  "services": {
    "otel-collector": {
      "name": "OTEL Collector",
      "icon": "📊",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "otel-collector/Dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "sleepApplication": false,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "env": {
        "TEMPO_ENDPOINT": "tempo.railway.internal:4317",
        "PROMETHEUS_ENDPOINT": "http://prometheus.railway.internal:9090/api/v1/write",
        "LOKI_ENDPOINT": "http://loki.railway.internal:3100/otlp"
      }
    },
    "tempo": {
      "name": "Tempo",
      "icon": "🔍",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "tempo/dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "sleepApplication": false,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    },
    "loki": {
      "name": "Loki",
      "icon": "📝",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "loki/dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "sleepApplication": false,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    },
    "prometheus": {
      "name": "Prometheus",
      "icon": "📈",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "prometheus/dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "sleepApplication": false,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    },
    "grafana": {
      "name": "Grafana",
      "icon": "📊",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "grafana/dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "healthcheckPath": "/api/health",
        "sleepApplication": false,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "env": {
        "LOKI_INTERNAL_URL": "http://loki.railway.internal:3100",
        "PROMETHEUS_INTERNAL_URL": "http://prometheus.railway.internal:9090",
        "TEMPO_INTERNAL_URL": "http://tempo.railway.internal:3200",
        "GF_SECURITY_ADMIN_USER": "admin",
        "GF_SECURITY_ADMIN_PASSWORD": {
          "generator": {
            "type": "secret"
          }
        },
        "GF_AUTH_ANONYMOUS_ENABLED": "false"
      }
    }
  }
}
